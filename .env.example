# --- ChunkScribe configuration ---

# Local proxy listener (point your Minecraft client here)
LISTEN_HOST=127.0.0.1
LISTEN_PORT=25566

# Target server you want to download
TARGET_HOST=play.example.com
TARGET_PORT=25565

# Microsoft account used to authenticate to TARGET (device-code flow on first run).
# Leave blank to be prompted at startup.
MS_EMAIL=

# Minecraft protocol version. Must match what TARGET expects AND what
# minecraft-protocol / prismarine-chunk support. Lower if 1.21.11 isn't ready.
MC_VERSION=1.21.11

# Where downloaded worlds are saved. Defaults to your Downloads folder.
# Each connection creates a subfolder named after TARGET_HOST.
# Examples:
#   OUTPUT_DIR=C:\Users\Jo\Downloads
#   OUTPUT_DIR=%APPDATA%\.minecraft\saves          (drop straight into singleplayer)
#   OUTPUT_DIR=.\worlds                            (keep next to project)
OUTPUT_DIR=

# Flush captured chunks to disk every N seconds (0 = only on disconnect).
FLUSH_INTERVAL_SEC=30

# Verbose packet logging
DEBUG=

# --- GUI ---
# GUI HTTP port (your browser connects here)
GUI_PORT=7878

# Set to 1 to skip auto-opening a browser tab on startup
NO_BROWSER=

# Set to 1 to start the proxy immediately on launch with the values above,
# instead of waiting for you to press Start in the GUI.
# (Only used if TARGET_HOST is set.)
AUTO_START=
