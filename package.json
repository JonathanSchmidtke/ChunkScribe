{
  "name": "chunkscribe",
  "version": "0.9.4",
  "private": false,
  "description": "Minecraft 1.21.11 MITM proxy that downloads the world to Anvil format while you play.",
  "main": "dist/index.js",
  "bin": {
    "chunkscribe": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "minecraft",
    "proxy",
    "world-downloader",
    "anvil",
    "1.21"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.0",
    "minecraft-protocol": "^1.66.0",
    "prismarine-chunk": "^1.40.0",
    "prismarine-nbt": "^2.8.0",
    "prismarine-provider-anvil": "^2.13.0",
    "prismarine-registry": "^1.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.22.0",
    "typescript": "^5.5.0"
  }
}
